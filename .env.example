# === BACKEND (SEGURANÇA) ===

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# POLLINATIONS_API_KEY: Required when AI_PROVIDER=pollinations.
POLLINATIONS_API_KEY="MY_POLLINATIONS_API_KEY"

# AI_PROVIDER: Active backend provider for the unified /api/ai facade.
# Supported values: pollinations | gemini
AI_PROVIDER="pollinations"

# SUPABASE_URL: URL do projeto Supabase usado pelo backend.
SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: chave de serviço do Supabase usada apenas no backend.
SUPABASE_SERVICE_ROLE_KEY="SUA_SERVICE_ROLE_KEY"

# DATABASE_URL: legado do fluxo Prisma.
# Mantido apenas para compatibilidade temporária e não é mais requerido pelo backend principal.
DATABASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# === FRONTEND (CLIENTE) ===

# GOOGLE_MAPS_API_KEY: Required for rendering Google Maps.
# Get one at https://console.cloud.google.com/google/maps-apis/credentials
VITE_GOOGLE_MAPS_API_KEY=""

# API base URL used by the mobile app build.
# Example: https://api.seudominio.com
# Leave empty for local web development using same-origin /api routes.
VITE_API_BASE_URL=""
