# === BACKEND (SEGURANÇA) ===

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: PostreSQL Connection String do Supabase (Acesso ao schema navegantes)
# Utilize a url de conexão de transação (Transaction Connection Pooler caso utilize ambiente serverless)
DATABASE_URL="postgresql://postgres.[SEU_ID]:[SUA_SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# === FRONTEND (CLIENTE) ===

# GOOGLE_MAPS_API_KEY: Required for rendering Google Maps.
# Get one at https://console.cloud.google.com/google/maps-apis/credentials
VITE_GOOGLE_MAPS_API_KEY=""

# API base URL used by the mobile app build.
# Example: https://api.seudominio.com
# Leave empty for local web development using same-origin /api routes.
VITE_API_BASE_URL=""
